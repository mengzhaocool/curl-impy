+/*
+ * curl-impersonate:
+ * Call curl_easy_setopt() with all the needed options as defined by the target
+ * */
+CURLcode curl_easy_impersonate_customized(struct Curl_easy *data,
+                                          const struct impersonate_opts *opts,
+                                          int default_headers)
+{
+  int ret;
+
+  ret = _do_impersonate(data, opts, default_headers);
+  if(ret)
+    return ret;
+
+  return CURLE_OK;
+}
+
+
+static const struct impersonate_opts *binary_search(size_t size, const char *key)
+{
+  int low = 0;
+  int high = size - 1;
+
+  while(low <= high) {
+    int mid = low + (high - low) / 2;
+    int cmp = strcmp(impersonations[mid].target, key);
+
+    if(cmp == 0) {
+      return &impersonations[mid];
+    } else if(cmp < 0) {
+      low = mid + 1;
+    } else {
+      high = mid - 1;
+    }
+  }
+
+  return NULL;
+}
+
+/*
+ * curl-impersonate:
+ * Call curl_easy_setopt() with all the needed options as defined in the
+ * 'impersonations' array.
+ * */
+CURLcode curl_easy_impersonate(CURL *data, const char *target,
+                               int default_headers)
+{
+  int ret;
+  const struct impersonate_opts *opts = NULL;
+  struct Curl_easy *_data = (struct Curl_easy *)data;
+
+  opts = binary_search(num_impersonations, target);
+
+  // If not found, fallback and search by alias again
+  if(opts == NULL) {
+    int i;
+    for(i = 0; i < num_impersonations; ++i) {
+      if (curl_strequal(target, impersonations[i].alias)) {
+        opts = impersonations + i;
+        break;
+      }
+    }
+  }
+
+  if(opts == NULL) {
+    /* Also search custom-registered browsers */
+    struct custom_impersonations *custom_reg = custom_impersonations_get();
+    int i;
+    if(custom_reg) {
+      for(i = 0; i < custom_reg->count; i++) {
+        if(curl_strequal(target, custom_reg->entries[i].target)) {
+          opts = &custom_reg->entries[i];
+          break;
+        }
+      }
+    }
+  }
+
+  if(opts == NULL) {
+    failf(_data, "Unknown impersonation target '%s'. "
+          "Use a valid --impersonate target such as firefox147.", target);
+    DEBUGF(fprintf(stderr, "Error: unknown impersonation target '%s'\n",
+                   target));
+    return CURLE_BAD_FUNCTION_ARGUMENT;
+  }
+
+  ret = _do_impersonate(_data, opts, default_headers);
+  if(ret)
+    return ret;
+
+  return CURLE_OK;
+}
+
+
+/*
+ * curl-impersonate:
+ * Return a curl_slist of all available impersonation target names.
+ * Includes both built-in and custom-registered targets.
+ * Caller must free with curl_slist_free_all().
+ */
+struct curl_slist *curl_easy_impersonate_list(void)
+{
+  struct curl_slist *list = NULL;
+  const struct impersonate_opts *opts;
+  struct custom_impersonations *custom_reg;
+  int i;
+
+  /* Add all built-in targets */
+  for(i = 0; i < (int)num_impersonations; i++) {
+    struct curl_slist *new_item = curl_slist_append(list, impersonations[i].target);
+    if(!new_item) {
+      curl_slist_free_all(list);
+      return NULL;
+    }
+    list = new_item;
+  }
+
+  /* Add all custom-registered targets */
+  custom_reg = custom_impersonations_get();
+  if(custom_reg) {
+    for(i = 0; i < custom_reg->count; i++) {
+      struct curl_slist *new_item = curl_slist_append(list,
+                                            custom_reg->entries[i].target);
+      if(!new_item) {
+        curl_slist_free_all(list);
+        return NULL;
+      }
+      list = new_item;
+    }
+  }
+
+  return list;
+}
