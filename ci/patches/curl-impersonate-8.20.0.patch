+    memcpy(algname, sigalgs, len);
+    algname[len] = 0;
+
+    for(i = 0; i < (int)MAX_SIG_ALGS; i++) {
+      if(strcasecompare(algname, kSignatureAlgorithmNames[i].name)) {
+        algs[*nalgs] = kSignatureAlgorithmNames[i].signature_algorithm;
+        (*nalgs)++;
+        found = TRUE;
+        break;
